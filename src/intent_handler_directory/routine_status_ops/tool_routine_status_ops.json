{
  "name": "routine_ops_tool",
  "description": "Perform runtime operations on a NuCore routine (enable, disable, run, stop, etc.)",
  "input_schema": {
    "type": "object",
    "required": ["args"],
    "properties": {
      "args": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "description": "The routine ID from ROUTINES RUNTIME DATA. Must match the 'id' field exactly."
            },
            "operation": {
              "type": "string",
              "enum": [
                "enable",
                "disable",
                "enableRunAtStartup",
                "disableRunAtStartup",
                "runThen",
                "runElse",
                "stop",
                "runIf"
              ],
              "description": "The operation to perform on the routine."
            }
          },
          "required": ["id", "operation"],
          "additionalProperties": false
        }
      }
    }
  }
}
