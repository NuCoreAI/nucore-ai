{
  "name": "nucore_router_tool",
  "description": "Results from routing and filtering top candidates based on the detected intent",
  "input_schema": {
    "type": "object",
    "required": ["intent"],
    "properties": {
      "intent": {
        "type": "string",
        "description": "Primary intent of the user query.",
        "enum": [
          "command_control",
          "routine_automation",
          "real_time_status",
          "group_scene_operations",
          "routine_status_ops"
        ]
      },
      "key": {
        "type": "string",
        "description": "The key for the candidates being returned. Such as `devices` and `routines` ",
        "enum": [
          "devices",
          "routines"
        ]
      },
      "devices": {
        "type": "array",
        "description": "Selected device/group/scene candidates for command_control, routine_automation, real_time_status, and group_scene_operations.",
        "items": {
          "type": "object",
          "required": ["device_id", "score"],
          "properties": {
            "device_id": {
              "type": "string",
              "description": "The unique device or group/scene identifier"
            },
            "score": {
              "type": "number",
              "description": "Relevance score from 0.0 to 1.0 inclusive (higher is better)",
              "minimum": 0,
              "maximum": 1
            }
          },
          "additionalProperties": false
        }
      },
      "routines": {
        "type": "array",
        "description": "Selected routine/folder candidates for routine_status_ops.",
        "items": {
          "type": "object",
          "required": ["routine_id", "score"],
          "properties": {
            "routine_id": {
              "type": "string",
              "description": "The unique routine/folder identifier"
            },
            "score": {
              "type": "number",
              "description": "Relevance score from 0.0 to 1.0 inclusive (higher is better)",
              "minimum": 0,
              "maximum": 1
            }
          },
          "additionalProperties": false
        }
      }
    },
    "additionalProperties": false
  }
}