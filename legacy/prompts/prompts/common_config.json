{
  "description": "Common configuration for NuCore prompts, including shared modules and agent definitions.",
  "version": "1.0.0",
  "modules":
  [
    {
        "name": "definitions",
        "description": "Core NuCore definitions and terminology",
        "path": "common/definitions.md", 
        "template_key": "<<nucore_definitions>>"
    },
    {
        "name": "security",
        "description": "Security validation and sanitization prompts",
        "path": "common/security.md", 
        "template_key": "<<nucore_security_rules>>"
    },
    {
        "name": "common",
        "description": "Common NuCore concepts/rules for command/control/automations",  
        "path": "common/common.md",
        "template_key": "<<nucore_common_rules>>"
    }
  ],

  "agents": [
        {
            "name": "command_control_status",
            "description": "Command, control, and realtime status agent for immediate device actions",
            "prompt": "agents/command_control_status.md",
            "retriever": {
                "class": "retrievers.device_candidates:DeviceCandidatesRetriever",
                "lifecycle": "singleton"
            },
            "intents_to_tools": [
                {
                    "intent": "command_control",
                    "tokens_per_message": 8000,
                    "tools":[
                        {
                            "name": "command_control_tool",
                            "path": "<<tools_path>>/command_control.json"
                        }
                    ]
                },
                {
                    "intent": "real_time_status",
                    "tokens_per_message": 5000,
                    "tools":[
                        {
                            "name": "real_time_status_tool",
                            "path": "<<tools_path>>/real_time_status.json"
                        }
                    ]
                }
            ],
            "include": [
                "definitions",
                "security",
                "common"
            ]
        },
        {
            "name": "routine_automation",
            "description": "Automation and scheduling prompts for conditional logic",
            "prompt": "agents/routine_automation.md",
            "retriever": {
                "class": "retrievers.device_candidates:DeviceCandidatesRetriever",
                "lifecycle": "singleton"
            },
            "intents_to_tools": [
                {
                    "intent": "routine_automation",
                    "tokens_per_message": 25000,
                    "tools":[
                        {
                            "name": "routine_automation_tool",
                            "path": "<<tools_path>>/routine_automation.json"
                        }
                    ]
                }
            ],
            "include": [
                "definitions",
                "security",
                "common"
            ]
        },
        {
            "name": "group_scene_operations",
            "description": "Group and scene operations for help and management of scenes and groups.",
            "prompt": "agents/group_scene_operations.md",
            "retriever": {
                "class": "retrievers.device_candidates:DeviceCandidatesRetriever",
                "lifecycle": "singleton"
            },
            "intents_to_tools": [
                {
                    "intent": "group_scene_operations",
                    "tokens_per_message": 25000,
                    "tools":[
                    ]
                }
            ],
            "include": [
                "definitions",
                "security",
                "common"
            ]
        },
        {
            "name": "routine_status_ops",
            "description": "Routine status operations for monitoring and managing routine states.",
            "prompt": "agents/routine_status_ops.md",
            "retriever": {
                "class": "retrievers.routine_candidates:RoutineCandidatesRetriever",
                "lifecycle": "singleton"
            },
            "intents_to_tools": [
                {
                    "intent": "routine_status_ops",
                    "tokens_per_message": 25000,
                    "tools":[
                        {
                            "name": "routine_status_ops_tool",
                            "path": "<<tools_path>>/routine_status_ops.json"
                        }
                    ]
                }
            ],
            "include": [
                "definitions",
                "security",
                "common"
            ]
        }
    ],
    "router": {
        "description": "Core router and definitions for intent classification and routing to agents/specialists",
        "path": "agents/router.md",
        "tokens_per_message": 20000,
        "score_threshold": 0.81,
        "tools": [
            {
                "name": "nucore_router_tool",
                "path": "<<tools_path>>/router.json"
            }
        ],
        "include": [
            "definitions"
        ]
  },
  "selector": {
        "description": "Core selector and definitions for intent classification and routing to agents/specialists",
        "path": "agents/selector.md",
        "tokens_per_message": 20000,
        "score_threshold": 0.81,
        "tools": [
            {
                "name": "nucore_selector_tool",
                "path": "<<tools_path>>/selector.json"
            }
        ],
        "include": [
            "definitions"
        ]
  }
}
